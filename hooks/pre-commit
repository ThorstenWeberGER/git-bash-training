#!/usr/bin/env bash
# Main Pre-Commit Hook
# Orchestrates all validation checks before commit
#
# Run order:
# 1. Secrets Detection
# 2. YAML Validation
# 3. Python Linting
# 4. SQL Linting (sqruff)
# 5. dbt Parse Validation
# 6. Large File Prevention

set -euo pipefail

# Get the directory where this script is located
HOOKS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Color codes
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

echo ""
echo "════════════════════════════════════════════════════════"
echo -e "${BLUE}🔍 Running Pre-Commit Validation${NC}"
echo "════════════════════════════════════════════════════════"
echo ""

# Array of hook scripts to run (in order)
hooks=(
  "pre-commit-secrets.sh"
  "pre-commit-yaml.sh"
  "pre-commit-python.sh"
  "pre-commit-sqruff.sh"
  "pre-commit-dbt.sh"
  "pre-commit-large-files.sh"
)

failed_hooks=()
hook_count=0

for hook in "${hooks[@]}"; do
  hook_path="$HOOKS_DIR/$hook"
  hook_count=$((hook_count + 1))

  if [ -f "$hook_path" ]; then
    if ! bash "$hook_path"; then
      failed_hooks+=("$hook")
    fi
  else
    echo "⚠️  Hook not found: $hook"
  fi
  echo ""
done

# Final result
echo "════════════════════════════════════════════════════════"

if [ ${#failed_hooks[@]} -eq 0 ]; then
  echo -e "${GREEN}✅ All pre-commit checks passed!${NC}"
  echo "════════════════════════════════════════════════════════"
  echo ""
  exit 0
else
  echo -e "${RED}❌ Pre-commit validation failed (${#failed_hooks[@]}/${hook_count} checks failed)${NC}"
  echo "════════════════════════════════════════════════════════"
  echo ""
  echo -e "${RED}Failed hooks:${NC}"
  for hook in "${failed_hooks[@]}"; do
    echo "   - $hook"
  done
  echo ""
  echo "Fix the issues above and try again:"
  echo "  git add <fixed-files>"
  echo "  git commit <message>"
  exit 1
fi
